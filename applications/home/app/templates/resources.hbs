{{page-title "Resources"}}
<div class="container-fluid px-0" style="max-width: 90%; margin: 0 auto;">
    <Navbar />

    <div class="container my-5">
  <div class="row justify-content-center">
    
    <div class="col-12 col-md-7 col-lg-6 text-center d-flex flex-column gap-3 align-items-center">

      <LinkTo @route="charts" @query={{hash type="charts"}} class="btn custom-btn w-100">
        Charts
      </LinkTo>

      <LinkTo @route="charts" @query={{hash type="vocabulary"}} class="btn custom-btn w-100">
        Vocabulary Cards
      </LinkTo>

      <LinkTo @route="charts" @query={{hash type="spoken"}} class="btn custom-btn w-100">
        Spoken English Activity
      </LinkTo>

      <LinkTo @route="charts" @query={{hash type="annual"}} class="btn custom-btn w-100">
        Annual Days
      </LinkTo>

      <LinkTo @route="index" class="mt-3 text-decoration-none d-flex flex-column align-items-center back-home-link">
        <span style="font-size: 3rem; color: rgb(2, 9, 137);">&#8592;</span>
        <span class="text-primary fs-5">Back to Home</span>
      </LinkTo>

    </div>

  </div>
</div>
</div>


{{outlet}}